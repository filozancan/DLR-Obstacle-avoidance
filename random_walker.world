          <geometry><cylinder><radius>0.2</radius><length>1.5</length></cylinder></geometry>
          <material><ambient>0.1 0.2 0.6 1</ambient><diffuse>0.1 0.2 0.6 1</diffuse></material>
        </visual>

        <collision name="head_collision">
          <pose>0 0 1.65 0 0 0</pose>
          <geometry><sphere><radius>0.15</radius></sphere></geometry>
        </collision>
        <visual name="head_visual">
          <pose>0 0 1.65 0 0 0</pose>
          <geometry><sphere><radius>0.15</radius></sphere></geometry>
          <material><ambient>0.9 0.7 0.6 1</ambient><diffuse>0.9 0.7 0.6 1</diffuse></material>
        </visual>
      </link>
      
      <plugin name="human_planar_move" filename="libgazebo_ros_planar_move.so">
        <ros>
          <namespace>/human</namespace>
          <remapping>cmd_vel:=cmd_vel</remapping>
        </ros>
        <update_rate>50.0</update_rate>
        <publish_rate>10.0</publish_rate>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <robot_base_frame>link</robot_base_frame>
      </plugin>
