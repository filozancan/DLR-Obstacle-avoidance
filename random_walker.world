    <model name="circular_obstacle">
      <pose>8.0 2.0 0.5 0 0 0</pose>
      <allow_auto_disable>0</allow_auto_disable>
      <link name="link">
        <inertial>
          <mass>100.0</mass>
          <inertia><ixx>10.0</ixx><iyy>10.0</iyy><izz>10.0</izz></inertia>
        </inertial>
        <collision name="collision">
          <geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.4</radius><length>1.0</length></cylinder></geometry>
          <material><ambient>0.8 0.8 0.1 1</ambient><diffuse>0.8 0.8 0.1 1</diffuse></material>
        </visual>
      </link>
      <plugin name="circular_obstacle_planar_move" filename="libgazebo_ros_planar_move.so">
        <ros>
          <namespace>/obstacle_circ</namespace>
          <remapping>cmd_vel:=cmd_vel</remapping>
        </ros>
        <update_rate>50.0</update_rate>
        <publish_rate>10.0</publish_rate>
        <publish_odom>false</publish_odom>
        <publish_odom_tf>false</publish_odom_tf>
        <robot_base_frame>link</robot_base_frame>
      </plugin>
    </model>

    <model name="random_human">
      <pose>3.0 2.0 0.0 0 0 0</pose>
      <allow_auto_disable>0</allow_auto_disable>
      <link name="link">
        <inertial>
          <mass>70.0</mass>
          <inertia><ixx>10.0</ixx><iyy>10.0</iyy><izz>10.0</izz></inertia>
        </inertial>
        
        <collision name="body_collision">
          <pose>0 0 0.75 0 0 0</pose>
          <geometry><cylinder><radius>0.2</radius><length>1.5</length></cylinder></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
